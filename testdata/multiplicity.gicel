-- GICEL Example: Multiplicity Annotations
--
-- Row fields can carry multiplicity annotations using @Mult.
--   @Linear    — must be consumed exactly once
--   @Affine    — may be consumed at most once
--   @Unrestricted — no usage restriction (default)
--
-- Multiplicities are checked by the type system during capability
-- row unification. They constrain how capabilities flow through
-- computations without affecting runtime behavior.
-- Level: types

import Prelude

form Mult := Unrestricted | Affine | Linear

-- A resource that must be consumed exactly once.
-- The @Linear annotation on handle tracks this at the type level.
open :: Computation {} { handle: () @Linear } ()
open := assumption

-- Using a linear resource preserves it in the post-state.
use :: Computation { handle: () @Linear } { handle: () @Linear } ()
use := assumption

-- Closing consumes the linear resource (removes from post-state).
close :: Computation { handle: () @Linear } {} ()
close := assumption

-- Valid lifecycle: open, use, close.
-- The capability row threading ensures @Linear is respected:
--   open:  {} → { handle: () @Linear }
--   use:   { handle: () @Linear } → { handle: () @Linear }
--   close: { handle: () @Linear } → {}
lifecycle :: Thunk { handle: () @Linear } {} ()
lifecycle := do { open; use; close }

-- Multiple uses before closing is also valid:
multiUse :: Thunk { handle: () @Linear } {} ()
multiUse := do { open; use; use; use; close }

-- The LUB (least upper bound) of multiplicities is definable as a type family:
type LUB :: Mult := \(m1: Mult) (m2: Mult). case (m1, m2) {
  (Linear, _) => Linear;
  (_, Linear) => Linear;
  (Affine, _) => Affine;
  (_, Affine) => Affine;
  (Unrestricted, Unrestricted) => Unrestricted
}

-- Note: opening without closing is a type error:
--   bad :: Thunk {} {} ()
--   bad := thunk do { open }
-- Error: post-state { handle: () @Linear } ≠ {}

-- Multiplicity annotations compose with row polymorphism.
-- Here, 'use' works in any environment that has a linear handle:
useOpen :: \(r: Row). Computation { handle: () @Linear | r } { handle: () @Linear | r } ()
useOpen := assumption

-- Output: this example demonstrates type-level guarantees.
-- At runtime, assumption-based primitives don't execute.
main := ()
