class Coercible a b { coerce :: a -> b }
class Convert a b { convert :: a -> b }
class Iso a b { to :: a -> b; from :: b -> a }

instance Coercible Bool () { coerce := \_ -> () }
instance Coercible () Bool { coerce := \_ -> True }
instance Coercible Bool Bool { coerce := \x -> x }
instance Coercible (Maybe Bool) Bool {
  coerce := \m -> case m { Just _ -> True; Nothing -> False }
}

instance Convert Bool (Maybe Bool) {
  convert := \b -> case b { True -> Just True; False -> Nothing }
}
instance Convert (Maybe Bool) Bool {
  convert := \m -> case m { Just _ -> True; Nothing -> False }
}

instance Iso Bool Bool { to := \x -> x; from := \x -> x }
instance Iso () () { to := \x -> x; from := \x -> x }

convertAndCoerce :: forall a b c. Convert a b => Coercible b c => a -> c
convertAndCoerce := \x -> coerce (convert x)

chainCoerce :: forall a b c. Coercible a b => Coercible b c => a -> c
chainCoerce := \x -> coerce (coerce x)

convertedBool := convertAndCoerce True

coerced1 := coerce True
coerced2 := (coerce :: () -> Bool) (coerce True)

main := case convertedBool { True -> coerced2; False -> False }
