-- Stress test 18: Literals and arithmetic
-- Tests Int/String/Rune literals, Num class, operator fixity, div/mod.

import Std.Num

-- Basic literal evaluation
litInt := 42
litNeg := negate 7

-- Arithmetic operations
arithAdd := 1 + 2
arithSub := 10 - 3
arithMul := 4 * 5
arithDiv := div 17 3
arithMod := mod 17 3

-- Operator fixity: * binds tighter than +
fixity1 := 1 + 2 * 3
fixity2 := 2 * 3 + 1

-- Chained operations
chain := 1 + 2 + 3 + 4

-- Eq and Ord for Int
eqTrue  := eq 42 42
eqFalse := eq 1 2
cmpLT := compare 1 2
cmpEQ := compare 5 5
cmpGT := compare 9 3

-- Nested arithmetic
nested := (1 + 2) * (3 + 4)

main := Pair litInt
             (Pair arithAdd
                   (Pair fixity1
                         (Pair chain
                               (Pair eqTrue
                                     (Pair cmpLT nested)))))
