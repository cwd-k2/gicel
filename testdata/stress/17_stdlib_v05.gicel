-- Stress test 17: v0.5 Stdlib expansion
-- Tests Semigroup, Monoid, Applicative, Traversable, and Ord completion.

-- Semigroup tests
sgOrdLT := append LT EQ
sgOrdEQ := append EQ GT
sgOrdGT := append GT LT
sgListAppend := append (Cons True Nil) (Cons False Nil)

-- Monoid tests
mnOrd  := (empty :: Ordering)
mnList := (empty :: List Bool)

-- Ord tests (Bool, Ordering, Maybe)
ordBool1 := compare False True
ordBool2 := compare True False
ordBool3 := compare True True
ordOrdLT := compare LT EQ
ordOrdGT := compare GT LT
ordMaybe1 := compare (Nothing :: Maybe Bool) (Just True)
ordMaybe2 := compare (Just False) (Just True)
ordMaybe3 := compare (Just True) (Nothing :: Maybe Bool)

-- Applicative tests
appWrap := (wrap True :: Maybe Bool)
appAp   := ap (Just (\x -> case x { True -> False; False -> True })) (Just True)

-- Traversable tests
travMaybeJust := traverse (\x -> Just x) (Just True)
travMaybeNothing := traverse (\x -> Just x) (Nothing :: Maybe Bool)

-- Functor List
fmapList := fmap (\x -> case x { True -> False; False -> True }) (Cons True Nil)

-- Foldable List
foldList := foldr (\x -> \acc -> x) False (Cons True Nil)

main := (sgOrdLT,
             (ordBool1,
                   (ordMaybe2,
                         (appWrap,
                               (travMaybeJust,
                                     (fmapList,
                                           (foldList, mnOrd)))))))
