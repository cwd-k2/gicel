getN :: forall (r : Row). () -> Computation { n : Int | r } { n : Int | r } Int
getN := assumption
incN :: forall (r : Row). () -> Computation { n : Int | r } { n : Int | r } ()
incN := assumption
addN :: forall (r : Row). Int -> Computation { n : Int | r } { n : Int | r } ()
addN := assumption

step :: () -> Computation { n : Int } { n : Int } ()
step := \_ -> do {
  v <- getN ();
  _ <- addN v;
  incN ()
}

main := do {
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  _ <- step ();
  getN ()
}
