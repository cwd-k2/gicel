import Prelude

type Eff := \r a. Computation r r a

data Ordering := { LT: Ordering; EQ: Ordering; GT: Ordering }
data Tree := \a. { Leaf: a -> Tree a; Branch: Tree a -> Tree a -> Tree a }
data Color := { Red: Color; Green: Color; Blue: Color }

data Eq := \a. { eq: a -> a -> Bool }
data Ord := \a. Eq a => { cmp: a -> a -> Ordering }
data Functor := \f. { fmap: \a b. (a -> b) -> f a -> f b }
data Coercible := \a b. { coerce: a -> b }

impl Eq Bool := {
  eq := \x y. case x {
    True  => y;
    False => case y { True => False; False => True }
  }
}
impl Eq () := { eq := \_ _. True }
impl Eq Ordering := {
  eq := \x y. case x {
    LT => case y { LT => True; _ => False };
    EQ => case y { EQ => True; _ => False };
    GT => case y { GT => True; _ => False }
  }
}
impl Eq Color := {
  eq := \x y. case x {
    Red   => case y { Red => True; _ => False };
    Green => case y { Green => True; _ => False };
    Blue  => case y { Blue => True; _ => False }
  }
}
impl Eq a => Eq (Maybe a) := {
  eq := \x y. case x {
    Nothing => case y { Nothing => True; Just _ => False };
    Just a  => case y { Nothing => False; Just b => eq a b }
  }
}
impl (Eq a) => (Eq b) => Eq (a, b) := {
  eq := \x y. case x {
    (a1, b1) => case y {
      (a2, b2) => case eq a1 a2 { True => eq b1 b2; False => False }
    }
  }
}

impl Ord Bool := {
  cmp := \x y. case x {
    False => case y { False => EQ; True => LT };
    True  => case y { False => GT; True => EQ }
  }
}

impl Functor Maybe := {
  fmap := \g mx. case mx {
    Nothing => Nothing;
    Just x  => Just (g x)
  }
}
impl Functor Tree := {
  fmap := \g t. case t {
    Leaf x     => Leaf (g x);
    Branch l r => Branch (fmap g l) (fmap g r)
  }
}

impl Coercible Bool () := { coerce := \_. () }
impl Coercible Color Bool := {
  coerce := \c. case c { Red => True; Green => False; Blue => True }
}

not := \b. case b { True => False; False => True }

genericEq :: \a. Eq a => a -> a -> Bool
genericEq := \x y. eq x y

liftMap :: \f a b. Functor f => (a -> b) -> f a -> f b
liftMap := \g fa. fmap g fa

eqViaOrd :: \a. Ord a => a -> a -> Bool
eqViaOrd := \x y. case cmp x y { EQ => True; _ => False }

convertAndCheck :: \a b. (Coercible a b, Eq b) => a -> b -> Bool
convertAndCheck := \x expected. eq (coerce x) expected

readS :: \(r: Row). () -> Computation { s: Int | r } { s: Int | r } Int
readS := assumption
writeS :: \(r: Row). Int -> Computation { s: Int | r } { s: Int | r } ()
writeS := assumption
intAdd :: Int -> Int -> Int
intAdd := assumption

stateful :: Int -> Eff { s: Int } Int
stateful := \delta. do {
  v <- readS ();
  _ <- writeS (intAdd v delta);
  readS ()
}

pipeline :: Thunk { s: Int } { s: Int } (Int, Bool)
pipeline := thunk (do {
  r1 <- stateful seed;
  r2 <- stateful r1;
  t := thunk (stateful r2);
  r3 <- force t;
  eqResult := {
    mapped := fmap not (Just True);
    case mapped { Just v => v; Nothing => True }
  };
  colorCheck := convertAndCheck Red True;
  pairEq := genericEq (True, False) (True, False);
  ordCheck := eqViaOrd True True;
  result := case eqResult {
    True  => case colorCheck {
      True  => case pairEq {
        True  => case ordCheck { True => True; False => False };
        False => False
      };
      False => False
    };
    False => False
  };
  pure (r3, result)
})

main := force pipeline
