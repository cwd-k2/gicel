import Prelude

type Eff := \r a. Computation r r a

form Ordering := { LT: Ordering; EQ: Ordering; GT: Ordering }
form Tree := \a. { Leaf: a -> Tree a; Branch: Tree a -> Tree a -> Tree a }
form Color := { Red: Color; Green: Color; Blue: Color }

form GEq := \a. { geq: a -> a -> Bool }
form GOrd := \a. GEq a => { gcmp: a -> a -> Ordering }
form GFunctor := \f. { gfmap: \a b. (a -> b) -> f a -> f b }
form Coercible := \a b. { coerce: a -> b }

impl GEq Bool := {
  geq := \x y. case x {
    True  => y;
    False => case y { True => False; False => True }
  }
}
impl GEq () := { geq := \_ _. True }
impl GEq Ordering := {
  geq := \x y. case x {
    LT => case y { LT => True; _ => False };
    EQ => case y { EQ => True; _ => False };
    GT => case y { GT => True; _ => False }
  }
}
impl GEq Color := {
  geq := \x y. case x {
    Red   => case y { Red => True; _ => False };
    Green => case y { Green => True; _ => False };
    Blue  => case y { Blue => True; _ => False }
  }
}
impl GEq a => GEq (Maybe a) := {
  geq := \x y. case x {
    Nothing => case y { Nothing => True; Just _ => False };
    Just a  => case y { Nothing => False; Just b => geq a b }
  }
}
impl (GEq a) => (GEq b) => GEq (a, b) := {
  geq := \x y. case x {
    (a1, b1) => case y {
      (a2, b2) => case geq a1 a2 { True => geq b1 b2; False => False }
    }
  }
}

impl GOrd Bool := {
  gcmp := \x y. case x {
    False => case y { False => EQ; True => LT };
    True  => case y { False => GT; True => EQ }
  }
}

impl GFunctor Maybe := {
  gfmap := \g mx. case mx {
    Nothing => Nothing;
    Just x  => Just (g x)
  }
}
impl GFunctor Tree := {
  gfmap := \g t. case t {
    Leaf x     => Leaf (g x);
    Branch l r => Branch (gfmap g l) (gfmap g r)
  }
}

impl Coercible Bool () := { coerce := \_. () }
impl Coercible Color Bool := {
  coerce := \c. case c { Red => True; Green => False; Blue => True }
}

not := \b. case b { True => False; False => True }

genericEq :: \a. GEq a => a -> a -> Bool
genericEq := \x y. geq x y

liftMap :: \f a b. GFunctor f => (a -> b) -> f a -> f b
liftMap := \g fa. gfmap g fa

eqViaOrd :: \a. GOrd a => a -> a -> Bool
eqViaOrd := \x y. case gcmp x y { EQ => True; _ => False }

convertAndCheck :: \a b. (Coercible a b, GEq b) => a -> b -> Bool
convertAndCheck := \x expected. geq (coerce x) expected

readS :: \(r: Row). () -> Computation { s: Int | r } { s: Int | r } Int
readS := assumption
writeS :: \(r: Row). Int -> Computation { s: Int | r } { s: Int | r } ()
writeS := assumption
intAdd :: Int -> Int -> Int
intAdd := assumption

stateful :: Int -> Eff { s: Int } Int
stateful := \delta. do {
  v <- readS ();
  _ <- writeS (intAdd v delta);
  readS ()
}

pipeline :: Thunk { s: Int } { s: Int } (Int, Bool)
pipeline := thunk (do {
  r1 <- stateful seed;
  r2 <- stateful r1;
  t := thunk (stateful r2);
  r3 <- force t;
  eqResult := {
    mapped := gfmap not (Just True);
    case mapped { Just v => v; Nothing => True }
  };
  colorCheck := convertAndCheck Red True;
  pairEq := genericEq (True, False) (True, False);
  ordCheck := eqViaOrd True True;
  result := case eqResult {
    True  => case colorCheck {
      True  => case pairEq {
        True  => case ordCheck { True => True; False => False };
        False => False
      };
      False => False
    };
    False => False
  };
  pure (r3, result)
})

main := force pipeline
