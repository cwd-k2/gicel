data Ordering = LT | EQ | GT

class Show a { tag :: a -> Bool }
class Show a => Eq a { eq :: a -> a -> Bool }
class Eq a => Ord a { compare :: a -> a -> Ordering }

instance Show Bool { tag := \_ -> True }
instance Show Unit { tag := \_ -> True }
instance Show Ordering {
  tag := \x -> case x { LT -> True; EQ -> True; GT -> True }
}

instance Eq Bool {
  eq := \x -> \y -> case x {
    True  -> y;
    False -> case y { True -> False; False -> True }
  }
}
instance Eq Unit { eq := \_ -> \_ -> True }
instance Eq Ordering {
  eq := \x -> \y -> case x {
    LT -> case y { LT -> True; _ -> False };
    EQ -> case y { EQ -> True; _ -> False };
    GT -> case y { GT -> True; _ -> False }
  }
}

instance Ord Bool {
  compare := \x -> \y -> case x {
    False -> case y { False -> EQ; True -> LT };
    True  -> case y { False -> GT; True -> EQ }
  }
}
instance Ord Unit { compare := \_ -> \_ -> EQ }
instance Ord Ordering {
  compare := \x -> \y -> case x {
    LT -> case y { LT -> EQ; _ -> LT };
    EQ -> case y { LT -> GT; EQ -> EQ; GT -> LT };
    GT -> case y { GT -> EQ; _ -> GT }
  }
}

useShow :: forall a. Eq a => a -> Bool
useShow := \x -> tag x

useEq :: forall a. Ord a => a -> a -> Bool
useEq := \x -> \y -> eq x y

compareAndEq :: forall a. Ord a => a -> a -> Pair Ordering Bool
compareAndEq := \x -> \y -> Pair (compare x y) (eq x y)

showViaOrd :: forall a. Ord a => a -> Bool
showViaOrd := \x -> tag x

isEqOrdering :: forall a. Ord a => a -> a -> Bool
isEqOrdering := \x -> \y -> case compare x y {
  EQ -> True;
  _  -> False
}

main := isEqOrdering True True
