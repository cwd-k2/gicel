import Prelude

data Coercible := \a b. { coerce: a -> b }
data Convert := \a b. { convert: a -> b }
data Iso := \a b. { to: a -> b; from: b -> a }

impl Coercible Bool () { coerce := \_. () }
impl Coercible () Bool { coerce := \_. True }
impl Coercible Bool Bool { coerce := \x. x }
impl Coercible (Maybe Bool) Bool {
  coerce := \m. case m { Just _ => True; Nothing => False }
}

impl Convert Bool (Maybe Bool) {
  convert := \b. case b { True => Just True; False => Nothing }
}
impl Convert (Maybe Bool) Bool {
  convert := \m. case m { Just _ => True; Nothing => False }
}

impl Iso Bool Bool { to := \x. x; from := \x. x }
impl Iso () () { to := \x. x; from := \x. x }

convertAndCoerce :: \a b c. (Convert a b, Coercible b c) => a -> c
convertAndCoerce := \x. coerce (convert x)

chainCoerce :: \a b c. (Coercible a b, Coercible b c) => a -> c
chainCoerce := \x. coerce (coerce x)

convertedBool := convertAndCoerce True

coerced1 := coerce True
coerced2 := (coerce :: () -> Bool) (coerce True)

main := case convertedBool { True => coerced2; False => False }
