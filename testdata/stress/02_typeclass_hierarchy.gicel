import Prelude

data Ordering := { LT: Ordering; EQ: Ordering; GT: Ordering }

data Show := \a. { tag: a -> Bool }
data Eq := \a. Show a => { eq: a -> a -> Bool }
data Ord := \a. Eq a => { compare: a -> a -> Ordering }

impl Show Bool := { tag := \_. True }
impl Show () := { tag := \_. True }
impl Show Ordering := {
  tag := \x. case x { LT => True; EQ => True; GT => True }
}

impl Eq Bool := {
  eq := \x y. case x {
    True  => y;
    False => case y { True => False; False => True }
  }
}
impl Eq () := { eq := \_ _. True }
impl Eq Ordering := {
  eq := \x y. case x {
    LT => case y { LT => True; _ => False };
    EQ => case y { EQ => True; _ => False };
    GT => case y { GT => True; _ => False }
  }
}

impl Ord Bool := {
  compare := \x y. case x {
    False => case y { False => EQ; True => LT };
    True  => case y { False => GT; True => EQ }
  }
}
impl Ord () := { compare := \_ _. EQ }
impl Ord Ordering := {
  compare := \x y. case x {
    LT => case y { LT => EQ; _ => LT };
    EQ => case y { LT => GT; EQ => EQ; GT => LT };
    GT => case y { GT => EQ; _ => GT }
  }
}

useShow :: \a. Eq a => a -> Bool
useShow := \x. tag x

useEq :: \a. Ord a => a -> a -> Bool
useEq := \x y. eq x y

compareAndEq :: \a. Ord a => a -> a -> (Ordering, Bool)
compareAndEq := \x y. (compare x y, eq x y)

showViaOrd :: \a. Ord a => a -> Bool
showViaOrd := \x. tag x

isEqOrdering :: \a. Ord a => a -> a -> Bool
isEqOrdering := \x y. case compare x y {
  EQ => True;
  _  => False
}

main := isEqOrdering True True
