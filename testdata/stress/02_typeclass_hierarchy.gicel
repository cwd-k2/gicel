import Prelude

form Ordering := { LT: Ordering; EQ: Ordering; GT: Ordering }

form GShow := \a. { gtag: a -> Bool }
form GEq := \a. GShow a => { geq: a -> a -> Bool }
form GOrd := \a. GEq a => { gcompare: a -> a -> Ordering }

impl GShow Bool := { gtag := \_. True }
impl GShow () := { gtag := \_. True }
impl GShow Ordering := {
  gtag := \x. case x { LT => True; EQ => True; GT => True }
}

impl GEq Bool := {
  geq := \x y. case x {
    True  => y;
    False => case y { True => False; False => True }
  }
}
impl GEq () := { geq := \_ _. True }
impl GEq Ordering := {
  geq := \x y. case x {
    LT => case y { LT => True; _ => False };
    EQ => case y { EQ => True; _ => False };
    GT => case y { GT => True; _ => False }
  }
}

impl GOrd Bool := {
  gcompare := \x y. case x {
    False => case y { False => EQ; True => LT };
    True  => case y { False => GT; True => EQ }
  }
}
impl GOrd () := { gcompare := \_ _. EQ }
impl GOrd Ordering := {
  gcompare := \x y. case x {
    LT => case y { LT => EQ; _ => LT };
    EQ => case y { LT => GT; EQ => EQ; GT => LT };
    GT => case y { GT => EQ; _ => GT }
  }
}

useShow :: \a. GEq a => a -> Bool
useShow := \x. gtag x

useEq :: \a. GOrd a => a -> a -> Bool
useEq := \x y. geq x y

compareAndEq :: \a. GOrd a => a -> a -> (Ordering, Bool)
compareAndEq := \x y. (gcompare x y, geq x y)

showViaOrd :: \a. GOrd a => a -> Bool
showViaOrd := \x. gtag x

isEqOrdering :: \a. GOrd a => a -> a -> Bool
isEqOrdering := \x y. case gcompare x y {
  EQ => True;
  _  => False
}

main := isEqOrdering True True
