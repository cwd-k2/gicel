-- DataKinds: state machine with phantom type indices
form DBState := Opened | Closed
form DB := \(s: DBState). { MkDB: DB s }

form Action := \(s: DBState). { MkAction: Action s }

-- Type-safe open/close using promoted constructors as kinds.
open :: DB Closed -> DB Opened
open := \_. MkDB

close :: DB Opened -> DB Closed
close := \_. MkDB

-- Chain multiple state transitions.
roundTrip :: DB Closed -> DB Closed
roundTrip := \db. close (open db)

-- Multi-step pipeline.
pipeline :: DB Closed -> DB Closed
pipeline := \db. roundTrip (roundTrip (roundTrip db))

main := pipeline MkDB
