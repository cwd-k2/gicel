import Prelude

data Color := { Red: Color; Green: Color; Blue: Color; Yellow: Color; Cyan: Color; Magenta: Color; White: Color; Black: Color }
data Shape := { Circle: Shape; Square: Shape; Triangle: Shape; Pentagon: Shape; Hexagon: Shape; Octagon: Shape }
data Day := { Mon: Day; Tue: Day; Wed: Day; Thu: Day; Fri: Day; Sat: Day; Sun: Day }
data Suit := { Spade: Suit; Heart: Suit; Diamond: Suit; Club: Suit }
data Prio := { Low: Prio; Medium: Prio; High: Prio; Critical: Prio; Blocker: Prio }
data Dir := { North: Dir; South: Dir; East: Dir; West: Dir; Up: Dir; Down: Dir }

colorToDay :: Color -> Day
colorToDay := \c. case c {
  Red     => Mon; Green   => Tue; Blue    => Wed;
  Yellow  => Thu; Cyan    => Fri; Magenta => Sat;
  White   => Sun; Black   => Mon
}

dayToShape :: Day -> Shape
dayToShape := \d. case d {
  Mon => Circle;   Tue => Square;    Wed => Triangle;
  Thu => Pentagon;  Fri => Hexagon;   Sat => Octagon;
  Sun => Circle
}

shapeToColor :: Shape -> Color
shapeToColor := \s. case s {
  Circle   => Red;    Square   => Green;  Triangle => Blue;
  Pentagon => Yellow; Hexagon  => Cyan;   Octagon  => Magenta
}

suitToPrio :: Suit -> Prio
suitToPrio := \s. case s {
  Spade => Critical; Heart => High; Diamond => Medium; Club => Low
}

prioToDir :: Prio -> Dir
prioToDir := \p. case p {
  Low => South; Medium => East; High => North; Critical => Up; Blocker => Down
}

dirToBool :: Dir -> Bool
dirToBool := \d. case d {
  North => True;  South => False; East => True;
  West  => False; Up    => True;  Down => False
}

not := \b. case b { True => False; False => True }

colorToBool :: Color -> Bool
colorToBool := \c. case c {
  Red => True; Green => False; Blue => True; Yellow => False;
  Cyan => True; Magenta => False; White => True; Black => False
}

pairMatch :: Color -> Shape -> Bool
pairMatch := \c s. case c {
  Red   => case s { Circle => True; _ => False };
  Green => case s { Square => True; _ => False };
  Blue  => case s { Triangle => True; _ => False };
  _     => False
}

tripleChain :: Color -> Bool
tripleChain := \c. dirToBool (prioToDir (suitToPrio (case c {
  Red => Spade; Green => Heart; Blue => Diamond;
  Yellow => Club; Cyan => Spade; Magenta => Heart;
  White => Diamond; Black => Club
})))

chainAll :: Color -> Shape
chainAll := \c. dayToShape (colorToDay c)

matchColor :: Color -> Color -> Bool
matchColor := \a b. case a {
  Red     => case b { Red => True; _ => False };
  Green   => case b { Green => True; _ => False };
  Blue    => case b { Blue => True; _ => False };
  Yellow  => case b { Yellow => True; _ => False };
  Cyan    => case b { Cyan => True; _ => False };
  Magenta => case b { Magenta => True; _ => False };
  White   => case b { White => True; _ => False };
  Black   => case b { Black => True; _ => False }
}

main := pairMatch (shapeToColor (chainAll Cyan)) (chainAll Cyan)
