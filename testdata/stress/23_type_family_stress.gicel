-- GICEL Example: Type Family Stress Test
--
-- This example exercises nested type families, recursive reduction,
-- and type-level computation in actual value-level code.
-- Level: types (advanced)
import Prelude

-- Peano naturals as DataKinds for type-level arithmetic.
form Nat := Z | S Nat

-- Phantom type indexed by Nat.
form NatProxy := \(n: Nat). { MkProxy: NatProxy n }

-- Type family that maps a container to its element type.
type ElemOf :: Type := \(c: Type). case c {
  List a => a;
  Maybe a => a
}

-- Type family that wraps a type in Maybe.
type Wrap :: Type := \(a: Type). case a {
  a => Maybe a
}

-- Nested type family usage: ElemOf (List (Wrap Int)) should reduce
-- to ElemOf (List (Maybe Int)) = Maybe Int.
unwrapList :: List (Wrap Int) -> ElemOf (List (Wrap Int))
unwrapList := \xs. case xs {
  Cons x _ => x;
  Nil => Nothing
}

-- Type-safe vector length at the type level.
-- A simple length-indexed structure using Peano.
form Vec := \(n: Nat) a. {
  VNil: Vec Z a;
  VCons: \(m: Nat). a -> Vec m a -> Vec (S m) a
}

-- Concrete usage: Vec (S (S Z)) Int (length 2)
pair :: Vec (S (S Z)) Int
pair := VCons 1 (VCons 2 VNil)

-- Vec Z Int (length 0)
empty :: Vec Z Int
empty := VNil

-- Season rotation uses recursive type family.
form Season := { Spring: Season; Summer: Season; Autumn: Season; Winter: Season }

type NextSeason :: Season := \(s: Season). case s {
  Spring => Summer;
  Summer => Autumn;
  Autumn => Winter;
  Winter => Spring
}

form Tagged := \(s: Season). { MkTagged: Tagged s }

-- NextSeason reduces concrete seasons at compile time.
advance :: \(s: Season). Tagged s -> Tagged (NextSeason s)
advance := \_. MkTagged

-- Type-safe progression: the type system guarantees the cycle.
spring :: Tagged Spring
spring := MkTagged

summer :: Tagged Summer
summer := advance spring

autumn :: Tagged Autumn
autumn := advance summer

winter :: Tagged Winter
winter := advance autumn

backToSpring :: Tagged Spring
backToSpring := advance winter

main := (pair, unwrapList (Cons (Just 10) Nil))
