import Prelude

form Tree := \a. { Leaf: a -> Tree a; Branch: Tree a -> Tree a -> Tree a }

form GFunctor := \f. { gfmap: \a b. (a -> b) -> f a -> f b }

impl GFunctor Maybe := {
  gfmap := \g mx. case mx {
    Nothing => Nothing;
    Just x  => Just (g x)
  }
}

impl GFunctor Tree := {
  gfmap := \g t. case t {
    Leaf x       => Leaf (g x);
    Branch l r   => Branch (gfmap g l) (gfmap g r)
  }
}

form GApplicative := \f. GFunctor f => {
  gwrap: \a. a -> f a
}

impl GApplicative Maybe := {
  gwrap := \x. Just x
}

not := \b. case b { True => False; False => True }

liftF :: \f a b. GFunctor f => (a -> b) -> f a -> f b
liftF := \g fa. gfmap g fa

doubleMap :: \f a b c. GFunctor f => (a -> b) -> (b -> c) -> f a -> f c
doubleMap := \g h fa. gfmap h (gfmap g fa)

applyNot :: \f. GFunctor f => f Bool -> f Bool
applyNot := \fb. gfmap not fb

treeOfBools := Branch (Leaf True) (Branch (Leaf False) (Leaf True))

mappedTree := gfmap not treeOfBools

main := case mappedTree {
  Branch l _ => case l {
    Leaf v => v;
    _      => True
  };
  Leaf v => v
}
