import Prelude

form Tree := \a. { Leaf: a -> Tree a; Branch: Tree a -> Tree a -> Tree a }

form Functor := \f. { fmap: \a b. (a -> b) -> f a -> f b }

impl Functor Maybe := {
  fmap := \g mx. case mx {
    Nothing => Nothing;
    Just x  => Just (g x)
  }
}

impl Functor Tree := {
  fmap := \g t. case t {
    Leaf x       => Leaf (g x);
    Branch l r   => Branch (fmap g l) (fmap g r)
  }
}

form Applicative := \f. Functor f => {
  wrap: \a. a -> f a
}

impl Applicative Maybe := {
  wrap := \x. Just x
}

not := \b. case b { True => False; False => True }

liftF :: \f a b. Functor f => (a -> b) -> f a -> f b
liftF := \g fa. fmap g fa

doubleMap :: \f a b c. Functor f => (a -> b) -> (b -> c) -> f a -> f c
doubleMap := \g h fa. fmap h (fmap g fa)

applyNot :: \f. Functor f => f Bool -> f Bool
applyNot := \fb. fmap not fb

treeOfBools := Branch (Leaf True) (Branch (Leaf False) (Leaf True))

mappedTree := fmap not treeOfBools

main := case mappedTree {
  Branch l _ => case l {
    Leaf v => v;
    _      => True
  };
  Leaf v => v
}
