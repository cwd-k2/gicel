_cmpStr :: String -> String -> Ordering
_cmpStr := assumption

_appendStr :: String -> String -> String
_appendStr := assumption

_emptyStr :: String
_emptyStr := assumption

_lengthStr :: String -> Int
_lengthStr := assumption

_eqRune :: Rune -> Rune -> Bool
_eqRune := assumption

_cmpRune :: Rune -> Rune -> Ordering
_cmpRune := assumption

impl Eq String := { eq := _eqStr }
impl Ord String := { compare := _cmpStr }
impl Semigroup String := { append := _appendStr }
impl Monoid String := { empty := _emptyStr }
impl Eq Rune := { eq := _eqRune }
impl Ord Rune := { compare := _cmpRune }

_eqByte :: Byte -> Byte -> Bool
