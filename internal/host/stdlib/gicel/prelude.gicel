contains :: String -> String -> Bool
contains := _contains

split :: String -> String -> List String
split := _split

join :: String -> List String -> String
join := _join

showInt :: Int -> String
showInt := show

showBool :: Bool -> String
showBool := \b. case b { True => "True"; False => "False" }

readInt :: String -> Maybe Int
readInt := _readInt

readDouble :: String -> Maybe Double
readDouble := _readDouble

words :: String -> List String
words := _words

form Read := \a. { read: String -> Maybe a }

impl Read Int    := { read := _readInt }
impl Read Double := { read := _readDouble }
impl Read String := { read := Just }

_toRunes :: String -> List Rune
_toRunes := assumption

toRunes :: String -> List Rune
toRunes := _toRunes

_fromRunes :: List Rune -> String
_fromRunes := assumption

fromRunes :: List Rune -> String
fromRunes := _fromRunes

impl FromList String := {
  type Elem := Rune;
  fromList := fromRunes
}

impl ToList String := { toList := toRunes }

_packRunes :: Slice Rune -> String
_packRunes := assumption

_unpackRunes :: String -> Slice Rune
_unpackRunes := assumption

_packBytes :: Slice Byte -> String
_packBytes := assumption

_unpackBytes :: String -> Slice Byte
_unpackBytes := assumption

impl Packed String Rune := {
  pack   := _packRunes;
  unpack := _unpackRunes
}

impl Packed String Byte := {
  pack   := _packBytes;
  unpack := _unpackBytes
}

impl Show String := { show := \s. append "\"" (append s "\"") }

impl Show a => Show (Maybe a) := {
  show := \m. case m {
    Nothing => "Nothing";
    Just a  => { s := show a; if contains " " s then "Just (" <> s <> ")" else "Just " <> s }
  }
}

impl Show a => Show (List a) := {
  show := \xs. append "[" (append (join ", " (fmap show xs)) "]")
}

impl (Show e, Show a) => Show (Result e a) := {
  show := \r. case r {
    Err e => { s := show e; if contains " " s then "Err (" <> s <> ")" else "Err " <> s };
    Ok a  => { s := show a; if contains " " s then "Ok (" <> s <> ")" else "Ok " <> s }
  }
}

impl (Show a, Show b) => Show (a, b) := {
  show := \p. append "(" (append (show (p.#_1)) (append ", " (append (show (p.#_2)) ")")))
}

-- ─── Bifunctor ──────────────────────────────────────────────────────────────

form Bifunctor := \(p: Type -> Type -> Type). {
  bimap: \a b c d. (a -> c) -> (b -> d) -> p a b -> p c d
}

bfirst :: \(p: Type -> Type -> Type) a b c. Bifunctor p => (a -> c) -> p a b -> p c b
bfirst := \f. bimap f id

bsecond :: \(p: Type -> Type -> Type) a b d. Bifunctor p => (b -> d) -> p a b -> p a d
bsecond := bimap id

impl Bifunctor Result := {
  bimap := \f g r. case r { Err e => Err (f e); Ok a => Ok (g a) }
}

-- Tuple bimap: standalone functions (no Bifunctor instance — tuple is built-in syntax)
bimapPair :: \a b c d. (a -> c) -> (b -> d) -> (a, b) -> (c, d)
bimapPair := \f g p. (f (fst p), g (snd p))

firstPair :: \a b c. (a -> c) -> (a, b) -> (c, b)
firstPair := \f p. (f (fst p), snd p)

secondPair :: \a b d. (b -> d) -> (a, b) -> (a, d)
secondPair := \g p. (fst p, g (snd p))

