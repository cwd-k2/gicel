_unlines := assumption

_isPrefixOfStr :: String -> String -> Bool
_isPrefixOfStr := assumption

_isSuffixOfStr :: String -> String -> Bool
_isSuffixOfStr := assumption

lines :: String -> List String
lines := _lines

unlines :: List String -> String
unlines := _unlines

unwords :: List String -> String
unwords := join " "

startsWith :: String -> String -> Bool
startsWith := _isPrefixOfStr

endsWith :: String -> String -> Bool
endsWith := _isSuffixOfStr

-- ─── Monadic combinators (Effect / Suspended scope) ─────────────────────────

mapM :: \a b (r: Row). (a -> Effect r b) -> List a -> Effect r (List b)
mapM := \f xs. case xs {
  Nil => pure Nil;
  Cons x rest => do {
    y  <- f x;
    ys <- mapM f rest;
    pure (Cons y ys)
  }
}

mapM_ :: \a b (r: Row). (a -> Effect r b) -> List a -> Effect r ()
mapM_ := \f xs. case xs {
  Nil => pure ();
  Cons x rest => do {
    _ <- f x;
    mapM_ f rest
  }
}

forM :: \a b (r: Row). List a -> (a -> Effect r b) -> Effect r (List b)
forM := flip mapM

forM_ :: \a b (r: Row). List a -> (a -> Effect r b) -> Effect r ()
forM_ := flip mapM_

sequence :: \a (r: Row). List (Effect r a) -> Effect r (List a)
sequence := mapM id

sequence_ :: \a (r: Row). List (Effect r a) -> Effect r ()
sequence_ := mapM_ id

foldM :: \a b (r: Row). (b -> a -> Effect r b) -> b -> List a -> Effect r b
foldM := \f acc xs. case xs {
  Nil => pure acc;
  Cons x rest => do {
    acc' <- f acc x;
    foldM f acc' rest
  }
}

filterM :: \a (r: Row). (a -> Effect r Bool) -> List a -> Effect r (List a)
filterM := \p xs. case xs {
  Nil => pure Nil;
  Cons x rest => do {
    keep <- p x;
    ys   <- filterM p rest;
    pure (if keep then Cons x ys else ys)
  }
}

replicateM :: \a (r: Row). Int -> Effect r a -> Effect r (List a)
replicateM := \n action. case n <= 0 {
  True => pure Nil;
  False => do {
    x  <- action;
    xs <- replicateM (n - 1) action;
    pure (Cons x xs)
  }
}
