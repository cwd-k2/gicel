-- ─── Additional Num ─────────────────────────────────────────────────────────

_gcd :: Int -> Int -> Int
_gcd := assumption

even :: Int -> Bool
even := \n. mod n 2 == 0

odd :: Int -> Bool
odd := \n. mod n 2 /= 0

gcd :: Int -> Int -> Int
gcd := _gcd

lcm :: Int -> Int -> Int
lcm := \a b. case _gcd a b { 0 => 0; g => abs (a / g * b) }

clamp :: \a. Ord a => (a, a) -> a -> a
clamp := \bounds x.
  case compare x (fst bounds) {
    LT => fst bounds;
    _ => case compare x (snd bounds) { GT => snd bounds; _ => x }
  }

-- ─── Additional List ────────────────────────────────────────────────────────

uncons :: \a. List a -> Maybe (a, List a)
uncons := \xs. case xs { Nil => Nothing; Cons x rest => Just (x, rest) }

listToMaybe :: \a. List a -> Maybe a
listToMaybe := head

maybeToList :: \a. Maybe a -> List a
maybeToList := \m. case m { Nothing => Nil; Just x => Cons x Nil }

minimum :: \a. Ord a => List a -> Maybe a
minimum := \xs. case xs {
  Nil => Nothing;
  Cons x rest => Just (foldl min x rest)
}

maximum :: \a. Ord a => List a -> Maybe a
maximum := \xs. case xs {
  Nil => Nothing;
  Cons x rest => Just (foldl max x rest)
}

sum :: List Int -> Int
sum := foldl _addInt 0

product :: List Int -> Int
product := foldl _mulInt 1

sumDouble :: List Double -> Double
sumDouble := foldl _addDouble 0.0

productDouble :: List Double -> Double
productDouble := foldl _mulDouble 1.0

_listGroupBy :: \a. (a -> a -> Bool) -> List a -> List (List a)
_listGroupBy := assumption

groupBy :: \a. (a -> a -> Bool) -> List a -> List (List a)
groupBy := _listGroupBy

group :: \a. Eq a => List a -> List (List a)
group := groupBy eq

minimumBy :: \a. (a -> a -> Ordering) -> List a -> Maybe a
minimumBy := \cmp xs. case xs {
  Nil => Nothing;
  Cons x rest => Just (foldl (\acc y. case cmp acc y { GT => y; _ => acc }) x rest)
}

maximumBy :: \a. (a -> a -> Ordering) -> List a -> Maybe a
maximumBy := \cmp xs. case xs {
  Nil => Nothing;
  Cons x rest => Just (foldl (\acc y. case cmp acc y { LT => y; _ => acc }) x rest)
}

isPrefixOf :: \a. Eq a => List a -> List a -> Bool
isPrefixOf := \prefix xs. case prefix {
  Nil => True;
  Cons p ps => case xs {
    Nil => False;
    Cons x rest => eq p x && isPrefixOf ps rest
  }
}

isSuffixOf :: \a. Eq a => List a -> List a -> Bool
isSuffixOf := \suffix xs. isPrefixOf (reverse suffix) (reverse xs)

