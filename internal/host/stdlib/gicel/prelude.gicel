form Bool := { True: Bool; False: Bool; }
form Result := \e a. { Ok: a -> Result e a; Err: e -> Result e a; }
form Maybe := \a. { Just: a -> Maybe a; Nothing: Maybe a; }
form List := \a. { Cons: a -> List a -> List a; Nil: List a; }
form Ordering := { LT: Ordering; EQ: Ordering; GT: Ordering; }

form Eq := \a. { eq: a -> a -> Bool }
form Ord := \a. Eq a => { compare: a -> a -> Ordering }
form Functor := \f. { fmap: \a b. (a -> b) -> f a -> f b }
form Foldable := \t. { foldr: \a b. (a -> b -> b) -> b -> t a -> b }

form Semigroup := \a. { append: a -> a -> a }
form Monoid := \a. Semigroup a => { empty: a }
form Applicative := \f. Functor f => {
  wrap: \a. a -> f a;
  ap   : \a b. f (a -> b) -> f a -> f b
}
form Traversable := \t. (Functor t, Foldable t) => {
  traverse: \f a b. Applicative f => (a -> f b) -> t a -> f (t b)
}

impl Eq Bool := {
  eq := \x y. case x {
    True => case y { True => True; False => False };
    False => case y { True => False; False => True }
  }
}

impl Eq () := { eq := \_ _. True }

impl Eq Ordering := {
  eq := \x y. case x {
    LT => case y { LT => True; EQ => False; GT => False };
    EQ => case y { LT => False; EQ => True; GT => False };
    GT => case y { LT => False; EQ => False; GT => True }
  }
}

impl Eq a => Eq (Maybe a) := {
  eq := \x y. case (x, y) {
    (Nothing, Nothing) => True;
    (Just a, Just b)   => eq a b;
    (Nothing, Just _)  => False;
    (Just _, Nothing)  => False
  }
}

impl (Eq a, Eq b) => Eq (a, b) := {
  eq := \x y. case (x, y) {
    ((a1, b1), (a2, b2)) => eq a1 a2 && eq b1 b2
  }
}

impl Functor Maybe := {
  fmap := \f ma. case ma {
    Nothing => Nothing;
    Just a => Just (f a)
  }
}

impl Foldable Maybe := {
  foldr := \f z ma. case ma {
    Nothing => z;
    Just a => f a z
  }
}

impl Semigroup () := { append := \_ _. () }
impl Semigroup Ordering := { append := \x y. case x { EQ => y; _ => x } }
impl Semigroup a => Semigroup (Maybe a) := {
  append := \x y. case x {
    Nothing => y;
    Just a => case y { Nothing => Just a; Just b => Just (append a b) }
  }
}
impl Monoid () := { empty := () }
impl Monoid Ordering := { empty := EQ }
impl Semigroup a => Monoid (Maybe a) := { empty := Nothing }

impl Ord Bool := {
  compare := \x y. case x {
    False => case y { False => EQ; True => LT };
    True  => case y { False => GT; True => EQ }
  }
}
impl Ord () := { compare := \_ _. EQ }
impl Ord Ordering := {
  compare := \x y. case x {
    LT => case y { LT => EQ; EQ => LT; GT => LT };
    EQ => case y { LT => GT; EQ => EQ; GT => LT };
    GT => case y { LT => GT; EQ => GT; GT => EQ }
  }
}
impl Ord a => Ord (Maybe a) := {
  compare := \x y. case (x, y) {
    (Nothing, Nothing) => EQ;
    (Nothing, Just _)  => LT;
    (Just _, Nothing)  => GT;
    (Just a, Just b)   => compare a b
  }
}
impl (Ord a, Ord b) => Ord (a, b) := {
  compare := \x y. case (x, y) {
    ((a1, b1), (a2, b2)) => append (compare a1 a2) (compare b1 b2)
  }
}

impl Applicative Maybe := {
  wrap := Just;
  ap := \mf mx. case mf {
    Nothing => Nothing;
    Just f  => case mx { Nothing => Nothing; Just x => Just (f x) }
  }
}

impl Traversable Maybe := {
  traverse := \f x. case x {
    Nothing => wrap Nothing;
    Just a  => fmap Just (f a)
  }
}

impl Eq a => Eq (List a) := {
  eq := \xs ys. case (xs, ys) {
    (Nil, Nil) => True;
    (Cons x rest, Cons y rest2) => eq x y && eq rest rest2;
    (Nil, Cons _ _) => False;
    (Cons _ _, Nil) => False
  }
}

impl Functor List := {
  fmap := \f xs. case xs {
    Nil => Nil;
    Cons x rest => Cons (f x) (fmap f rest)
  }
}

impl Foldable List := {
  foldr := \f z xs. case xs {
    Nil => z;
    Cons x rest => f x (foldr f z rest)
  }
}

impl Semigroup (List a) := {
  append := \xs ys. case xs {
    Nil => ys;
    Cons x rest => Cons x (append rest ys)
  }
}

impl Monoid (List a) := { empty := Nil }

id :: \a. a -> a
id := \x. x

const :: \a b. a -> b -> a
const := \x _. x

flip :: \a b c. (a -> b -> c) -> b -> a -> c
flip := \f b a. f a b

infixr 9 .
(.) :: \b c a. (b -> c) -> (a -> b) -> a -> c
(.) := \f g x. f (g x)

not :: Bool -> Bool
not := \b. case b { True => False; False => True }

infixr 3 &&
(&&) :: Bool -> Bool -> Bool
(&&) := \x y. case x { False => False; True => y }

infixr 2 ||
(||) :: Bool -> Bool -> Bool
(||) := \x y. case x { True => True; False => y }

maybe :: \a b. b -> (a -> b) -> Maybe a -> b
maybe := \def f m. case m { Nothing => def; Just a => f a }

result :: \e a b. (e -> b) -> (a -> b) -> Result e a -> b
result := \onErr onOk r. case r { Err e => onErr e; Ok a => onOk a }

fst :: \a (r: Row). Record { _1: a | r } -> a
fst := \p. p.#_1

snd :: \a (r: Row). Record { _2: a | r } -> a
snd := \p. p.#_2

head :: \a. List a -> Maybe a
head := \xs. case xs { Nil => Nothing; Cons x _ => Just x }

tail :: \a. List a -> Maybe (List a)
tail := \xs. case xs { Nil => Nothing; Cons _ rest => Just rest }

null :: \a. List a -> Bool
null := \xs. case xs { Nil => True; Cons _ _ => False }

map :: \a b. (a -> b) -> List a -> List b
map := fmap

filter :: \a. (a -> Bool) -> List a -> List a
filter := \p. foldr (\x acc. case p x { True => Cons x acc; False => acc }) Nil

singleton :: \a. a -> List a
singleton := \x. Cons x Nil

infixn 4 ==
infixn 4 /=
infixn 4 <
infixn 4 >
infixn 4 <=
infixn 4 >=

(==) :: \a. Eq a => a -> a -> Bool
(==) := eq

(/=) :: \a. Eq a => a -> a -> Bool
(/=) := \x y. not (eq x y)

(<) :: \a. Ord a => a -> a -> Bool
(<) := \x y. case compare x y { LT => True; _ => False }

(>) :: \a. Ord a => a -> a -> Bool
(>) := \x y. case compare x y { GT => True; _ => False }

(<=) :: \a. Ord a => a -> a -> Bool
(<=) := \x y. case compare x y { GT => False; _ => True }

(>=) :: \a. Ord a => a -> a -> Bool
(>=) := \x y. case compare x y { LT => False; _ => True }

min :: \a. Ord a => a -> a -> a
min := \x y. case compare x y { GT => y; _ => x }

max :: \a. Ord a => a -> a -> a
max := \x y. case compare x y { LT => y; _ => x }

infixr 6 <>
(<>) :: \a. Semigroup a => a -> a -> a
(<>) := append

infixr 5 <+
(<+) :: \a. a -> List a -> List a
(<+) := Cons

form Show := \a. { show: a -> String }
impl Show Bool := { show := \b. case b { True => "True"; False => "False" } }
impl Show () := { show := \_. "()" }
impl Show Ordering := { show := \x. case x { LT => "LT"; EQ => "EQ"; GT => "GT" } }

form Alternative := \f. Applicative f => {
  none: \a. f a;
  alt  : \a. f a -> f a -> f a
}
infixl 3 <|>
(<|>) :: \(f: Type -> Type) a. Alternative f => f a -> f a -> f a
(<|>) := alt

impl Alternative Maybe := {
  none := Nothing;
  alt  := \x y. case x { Just _ => x; Nothing => y }
}

impl Alternative List := { none := Nil; alt := append }

guard :: \(f: Type -> Type). Alternative f => Bool -> f ()
guard := \b. case b { True => wrap (); False => none }

form Monad := \(m: Type -> Type). {
  mpure: \a. a -> m a;
  mbind: \a b. m a -> (a -> m b) -> m b
}

impl Monad Maybe := {
  mpure := Just;
  mbind := \ma f. case ma { Nothing => Nothing; Just a => f a }
}

impl Monad List := {
  mpure := singleton;
  mbind := \xs f. foldr (\x acc. append (f x) acc) Nil xs
}

infixl 1 >>=
(>>=) :: \(m: Type -> Type) a b. Monad m => m a -> (a -> m b) -> m b
(>>=) := mbind

infixl 1 >>
(>>) :: \(m: Type -> Type) a b. Monad m => m a -> m b -> m b
(>>) := \m1 m2. mbind m1 (\_. m2)

-- IxMonad instances for Maybe and List provide `pure`/`ixpure` dispatch
-- in monadic contexts (e.g. `Just 5 >>= \x. pure x`). Auto-lifted to
-- IxMonad (Lift Maybe) / IxMonad (Lift List) by the checker.
impl IxMonad Maybe := {
  ixpure := Just;
  ixbind := \ma f. case ma {
    Nothing => Nothing;
    Just a  => f a
  }
}

impl IxMonad List := {
  ixpure := singleton;
  ixbind := \xs f. foldr (\x acc. append (f x) acc) Nil xs
}

form Packed := \c e. {
  pack:   Slice e -> c;
  unpack: c -> Slice e
}

form FromList := \l. {
  type Elem l :: Type;
  fromList: List (Elem l) -> l
}

form ToList := \l. FromList l => {
  toList: l -> List (Elem l)
}

impl FromList (List a) := {
  type Elem := a;
  fromList := id
}

impl ToList (List a) := { toList := id }

impl FromList (Maybe a) := {
  type Elem := a;
  fromList := head
}

impl ToList (Maybe a) := {
  toList := \m. case m { Nothing => Nil; Just x => Cons x Nil }
}

impl Applicative List := {
  wrap := singleton;
  ap := \fs xs. foldr (\f acc. append (fmap f xs) acc) Nil fs
}

impl Traversable List := {
  traverse := \f. foldr (\x acc. ap (fmap Cons (f x)) acc) (wrap Nil)
}

impl (Eq e, Eq a) => Eq (Result e a) := {
  eq := \x y. case (x, y) {
    (Ok a1, Ok a2)   => eq a1 a2;
    (Err e1, Err e2) => eq e1 e2;
    (Ok _, Err _)    => False;
    (Err _, Ok _)    => False
  }
}

impl (Ord e, Ord a) => Ord (Result e a) := {
  compare := \x y. case (x, y) {
    (Err e1, Err e2) => compare e1 e2;
    (Err _, Ok _)    => LT;
    (Ok _, Err _)    => GT;
    (Ok a1, Ok a2)   => compare a1 a2
  }
}

impl Functor (Result e) := {
  fmap := \f r. case r {
    Err x => Err x;
    Ok a => Ok (f a)
  }
}

impl Foldable (Result e) := {
  foldr := \f z r. case r {
    Err _ => z;
    Ok a => f a z
  }
}

impl Ord a => Ord (List a) := {
  compare := \xs ys. case (xs, ys) {
    (Nil, Nil) => EQ;
    (Nil, Cons _ _) => LT;
    (Cons _ _, Nil) => GT;
    (Cons x rest, Cons y rest2) => case compare x y { EQ => compare rest rest2; c => c }
  }
}

infixr 0 $
($) :: \a b. (a -> b) -> a -> b
($) := \f x. f x

infixl 1 &
(&) :: \a b. a -> (a -> b) -> b
(&) := \x f. f x

infixl 4 <$>
(<$>) :: \(f: Type -> Type) a b. Functor f => (a -> b) -> f a -> f b
(<$>) := fmap

infixl 1 <&>
(<&>) :: \(f: Type -> Type) a b. Functor f => f a -> (a -> b) -> f b
(<&>) := flip fmap

infixl 4 <*>
(<*>) :: \(f: Type -> Type) a b. Applicative f => f (a -> b) -> f a -> f b
(<*>) := ap

infixl 4 *>
(*>) :: \(f: Type -> Type) a b. Applicative f => f a -> f b -> f b
(*>) := \fa fb. ap (fmap (const id) fa) fb

infixl 4 <*
(<*) :: \(f: Type -> Type) a b. Applicative f => f a -> f b -> f a
(<*) := \fa fb. ap (fmap const fa) fb

infixr 1 =<<
(=<<) :: \(m: Type -> Type) a b. Monad m => (a -> m b) -> m a -> m b
(=<<) := flip mbind

infixr 1 >=>
(>=>) :: \(m: Type -> Type) a b c. Monad m => (a -> m b) -> (b -> m c) -> a -> m c
(>=>) := \f g a. mbind (f a) g

infixr 1 <=<
(<=<) :: \(m: Type -> Type) b c a. Monad m => (b -> m c) -> (a -> m b) -> a -> m c
(<=<) := \g f a. mbind (f a) g

on :: \a b c. (b -> b -> c) -> (a -> b) -> a -> a -> c
on := \f g x y. f (g x) (g y)

comparing :: \a b. Ord b => (a -> b) -> a -> a -> Ordering
comparing := \f. on compare f

equating :: \a b. Eq b => (a -> b) -> a -> a -> Bool
equating := \f. on eq f

isJust :: \a. Maybe a -> Bool
isJust := \m. case m { Just _ => True; Nothing => False }

isNothing :: \a. Maybe a -> Bool
isNothing := \m. case m { Just _ => False; Nothing => True }

isOk :: \e a. Result e a -> Bool
isOk := \r. case r { Ok _ => True; Err _ => False }

isErr :: \e a. Result e a -> Bool
isErr := \r. case r { Ok _ => False; Err _ => True }

fromOk :: \e a. a -> Result e a -> a
fromOk := \def r. case r { Ok x => x; Err _ => def }

fromErr :: \e a. e -> Result e a -> e
fromErr := \def r. case r { Err x => x; Ok _ => def }

bool :: \a. a -> a -> Bool -> a
bool := \f t b. case b { False => f; True => t }

swap :: \a b. (a, b) -> (b, a)
swap := \p. (snd p, fst p)

curry :: \a b c. ((a, b) -> c) -> a -> b -> c
curry := \f a b. f (a, b)

uncurry :: \a b c. (a -> b -> c) -> (a, b) -> c
uncurry := \f p. f (fst p) (snd p)

mjoin :: \(m: Type -> Type) a. Monad m => m (m a) -> m a
mjoin := \mma. mbind mma id

when :: \(m: Type -> Type). Monad m => Bool -> m () -> m ()
when := \b action. case b { True => action; False => mpure () }

unless :: \(m: Type -> Type). Monad m => Bool -> m () -> m ()
unless := \b. when (not b)

void :: \(f: Type -> Type) a. Functor f => f a -> f ()
void := fmap (const ())

liftA2 :: \(f: Type -> Type) a b c. Applicative f => (a -> b -> c) -> f a -> f b -> f c
liftA2 := \f fa fb. ap (fmap f fa) fb

foldMap :: \(t: Type -> Type) a m. (Foldable t, Monoid m) => (a -> m) -> t a -> m
foldMap := \f. foldr (\x acc. append (f x) acc) empty

collectList :: \(t: Type -> Type) a. Foldable t => t a -> List a
collectList := foldr Cons Nil

find :: \a. (a -> Bool) -> List a -> Maybe a
find := \p. foldr (\x acc. case p x { True => Just x; False => acc }) Nothing

elem :: \a. Eq a => a -> List a -> Bool
elem := \x. foldr (\y acc. case eq x y { True => True; False => acc }) False

notElem :: \a. Eq a => a -> List a -> Bool
notElem := \x. not . elem x

any :: \a. (a -> Bool) -> List a -> Bool
any := \p. foldr (\x acc. case p x { True => True; False => acc }) False

all :: \a. (a -> Bool) -> List a -> Bool
all := \p. foldr (\x acc. case p x { True => acc; False => False }) True

and :: List Bool -> Bool
and := foldr (&&) True

or :: List Bool -> Bool
or := foldr (||) False

lookup :: \a b. Eq a => a -> List (a, b) -> Maybe b
lookup := \key. foldr (\pair acc. case eq key (fst pair) { True => Just (snd pair); False => acc }) Nothing

concatMap :: \a b. (a -> List b) -> List a -> List b
concatMap := \f. foldr (\x acc. append (f x) acc) Nil

flatten :: \a. List (List a) -> List a
flatten := foldr append Nil

catMaybes :: \a. List (Maybe a) -> List a
catMaybes := foldr (\m acc. case m { Just a => Cons a acc; Nothing => acc }) Nil

mapMaybe :: \a b. (a -> Maybe b) -> List a -> List b
mapMaybe := \f. foldr (\x acc. case f x { Just b => Cons b acc; Nothing => acc }) Nil

partition :: \a. (a -> Bool) -> List a -> (List a, List a)
partition := \p. foldr (\x acc. case p x {
  True => (Cons x (fst acc), snd acc);
  False => (fst acc, Cons x (snd acc))
}) (Nil, Nil)

takeWhile :: \a. (a -> Bool) -> List a -> List a
takeWhile := \p. foldr (\x acc. case p x { True => Cons x acc; False => Nil }) Nil

intersperse :: \a. a -> List a -> List a
intersperse := \sep xs. case xs {
  Nil => Nil;
  Cons x rest => Cons x (foldr (\y acc. Cons sep (Cons y acc)) Nil rest)
}

nub :: \a. Eq a => List a -> List a
nub := nubBy (==)

-- ─── Num ─────────────────────────────────────────────────────────────────────

_addInt :: Int -> Int -> Int
_addInt := assumption

_subInt :: Int -> Int -> Int
_subInt := assumption

_mulInt :: Int -> Int -> Int
_mulInt := assumption

_divInt :: Int -> Int -> Int
_divInt := assumption

_modInt :: Int -> Int -> Int
_modInt := assumption

_negInt :: Int -> Int
_negInt := assumption

_eqInt :: Int -> Int -> Bool
_eqInt := assumption

_cmpInt :: Int -> Int -> Ordering
_cmpInt := assumption

_showInt :: Int -> String
_showInt := assumption

impl Show Int := { show := _showInt }
impl Eq Int := { eq := _eqInt }
impl Ord Int := { compare := _cmpInt }
impl Semigroup Int := { append := _addInt }
impl Monoid Int := { empty := 0 }

form Num := \a. Eq a => {
  add    : a -> a -> a;
  sub    : a -> a -> a;
  mul    : a -> a -> a;
  negate: a -> a
}

impl Num Int := {
  add := _addInt;
  sub := _subInt;
  mul := _mulInt;
  negate := _negInt
}

form Div := \a. Num a => {
  div: a -> a -> a
}

impl Div Int := { div := _divInt }

mod :: Int -> Int -> Int
mod := _modInt

_addDouble :: Double -> Double -> Double
_addDouble := assumption

_subDouble :: Double -> Double -> Double
_subDouble := assumption

_mulDouble :: Double -> Double -> Double
_mulDouble := assumption

_negDouble :: Double -> Double
_negDouble := assumption

_eqDouble :: Double -> Double -> Bool
_eqDouble := assumption

_cmpDouble :: Double -> Double -> Ordering
_cmpDouble := assumption

_showDouble :: Double -> String
_showDouble := assumption

impl Show Double := { show := _showDouble }
impl Eq Double := { eq := _eqDouble }
impl Ord Double := { compare := _cmpDouble }

impl Num Double := {
  add := _addDouble;
  sub := _subDouble;
  mul := _mulDouble;
  negate := _negDouble
}

impl Semigroup Double := { append := _addDouble }
impl Monoid Double := { empty := 0.0 }

impl Div Double := { div := _divDouble }

_divDouble :: Double -> Double -> Double
_divDouble := assumption

_toDouble :: Int -> Double
_toDouble := assumption

_round :: Double -> Int
_round := assumption

_floor :: Double -> Int
_floor := assumption

_ceiling :: Double -> Int
_ceiling := assumption

_truncate :: Double -> Int
_truncate := assumption

toDouble :: Int -> Double
toDouble := _toDouble

round :: Double -> Int
round := _round

floor :: Double -> Int
floor := _floor

ceiling :: Double -> Int
ceiling := _ceiling

truncate :: Double -> Int
truncate := _truncate

infixl 6 +
infixl 6 -
infixl 7 *
infixl 7 /

(+) :: \a. Num a => a -> a -> a
(+) := add

(-) :: \a. Num a => a -> a -> a
(-) := sub

(*) :: \a. Num a => a -> a -> a
(*) := mul

(/) :: \a. Div a => a -> a -> a
(/) := div

abs :: Int -> Int
abs := \x. case _cmpInt x 0 { LT => negate x; _ => x }

sign :: Int -> Int
sign := \x. case _cmpInt x 0 { LT => negate 1; EQ => 0; GT => 1 }

absDouble :: Double -> Double
absDouble := \x. case _cmpDouble x 0.0 { LT => _negDouble x; _ => x }

signDouble :: Double -> Double
signDouble := \x. case _cmpDouble x 0.0 { LT => _negDouble 1.0; EQ => 0.0; GT => 1.0 }

-- ─── List operations ─────────────────────────────────────────────────────────

_listFromSlice :: \a. List a -> List a
_listFromSlice := assumption

_listToSlice :: \a. List a -> List a
_listToSlice := assumption

_listLength :: \a. List a -> Int
_listLength := assumption

_listConcat :: \a. List a -> List a -> List a
_listConcat := assumption

fromSlice :: \a. List a -> List a
fromSlice := _listFromSlice

toSlice :: \a. List a -> List a
toSlice := _listToSlice

length :: \a. List a -> Int
length := _listLength

concat :: \a. List a -> List a -> List a
concat := _listConcat

_listFoldl :: \a b. (b -> a -> b) -> b -> List a -> b
_listFoldl := assumption

_listTake :: \a. Int -> List a -> List a
_listTake := assumption

_listDrop :: \a. Int -> List a -> List a
_listDrop := assumption

_listIndex :: \a. Int -> List a -> Maybe a
_listIndex := assumption

_listReplicate :: \a. Int -> a -> List a
_listReplicate := assumption

_listReverse :: \a. List a -> List a
_listReverse := assumption

_listRange :: Int -> Int -> List Int
_listRange := assumption

_listZip :: \a b. List a -> List b -> List (a, b)
_listZip := assumption

_listUnzip :: \a b. List (a, b) -> (List a, List b)
_listUnzip := assumption

foldl :: \a b. (b -> a -> b) -> b -> List a -> b
foldl := _listFoldl

take :: \a. Int -> List a -> List a
take := _listTake

drop :: \a. Int -> List a -> List a
drop := _listDrop

index :: \a. Int -> List a -> Maybe a
index := _listIndex

replicate :: \a. Int -> a -> List a
replicate := _listReplicate

range :: Int -> Int -> List Int
range := _listRange

reverse :: \a. List a -> List a
reverse := _listReverse

zip :: \a b. List a -> List b -> List (a, b)
zip := _listZip

unzip :: \a b. List (a, b) -> (List a, List b)
unzip := _listUnzip

_listDropWhile :: \a. (a -> Bool) -> List a -> List a
_listDropWhile := assumption

_listSpan :: \a. (a -> Bool) -> List a -> (List a, List a)
_listSpan := assumption

_listSortBy :: \a. (a -> a -> Ordering) -> List a -> List a
_listSortBy := assumption

_listScanl :: \a b. (b -> a -> b) -> b -> List a -> List b
_listScanl := assumption

_listUnfoldr :: \a b. (b -> Maybe (a, b)) -> b -> List a
_listUnfoldr := assumption

_listIterateN :: \a. Int -> (a -> a) -> a -> List a
_listIterateN := assumption

dropWhile :: \a. (a -> Bool) -> List a -> List a
dropWhile := _listDropWhile

span :: \a. (a -> Bool) -> List a -> (List a, List a)
span := _listSpan

break :: \a. (a -> Bool) -> List a -> (List a, List a)
break := \p. span (not . p)

sortBy :: \a. (a -> a -> Ordering) -> List a -> List a
sortBy := _listSortBy

sort :: \a. Ord a => List a -> List a
sort := sortBy compare

scanl :: \a b. (b -> a -> b) -> b -> List a -> List b
scanl := _listScanl

unfoldr :: \a b. (b -> Maybe (a, b)) -> b -> List a
unfoldr := _listUnfoldr

iterateN :: \a. Int -> (a -> a) -> a -> List a
iterateN := _listIterateN

zipWith :: \a b c. (a -> b -> c) -> List a -> List b -> List c
zipWith := \f xs ys. map (uncurry f) (zip xs ys)

intercalate :: \a. List a -> List (List a) -> List a
intercalate := \sep xss. flatten (intersperse sep xss)

nubBy :: \a. (a -> a -> Bool) -> List a -> List a
nubBy := \eq. foldl (\acc x. case any (eq x) acc { True => acc; False => append acc (singleton x) }) Nil

