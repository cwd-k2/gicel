import Prelude

get :: \s r. Effect { state: s | r } s
get := assumption

put :: \s1 s2 r. s2 -> Computation { state: s1 | r } { state: s2 | r } ()
put := assumption

modify :: \s r. (s -> s) -> Effect { state: s | r } ()
modify := \f. do { s <- get; put (f s) }

-- Named capability variants: label-parameterized state access.
getAt :: \(l: Label) s r. Effect { l: s | r } s
getAt := assumption

putAt :: \(l: Label) s1 s2 r. s2 -> Computation { l: s1 | r } { l: s2 | r } ()
putAt := assumption
