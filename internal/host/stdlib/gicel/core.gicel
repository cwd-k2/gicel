-- Grade algebra: the foundation of graded indexed monads.
form GradeAlgebra := \(g: Kind). {
  type GradeJoin :: g -> g -> g;
  type GradeCompose :: g -> g -> g;
  type GradeDrop :: g;
  type GradeUnit :: g
}

-- Trivial grade algebra: a single-element grade that carries no information.
-- Used for ungraded indexed monads (GIMonad Trivial).
form Trivial := { Triv: Trivial }

type TrivialJoin :: Trivial -> Trivial -> Trivial :=
  \(a: Trivial) (b: Trivial). Triv
type TrivialCompose :: Trivial -> Trivial -> Trivial :=
  \(a: Trivial) (b: Trivial). Triv

impl GradeAlgebra Trivial := {
  type GradeJoin := TrivialJoin;
  type GradeCompose := TrivialCompose;
  type GradeDrop := Triv;
  type GradeUnit := Triv
}

-- UsageSemiring: value-level operations on grade values.
-- Parallel to GradeAlgebra (type-level), enabling runtime grade arithmetic.
-- Laws (not enforced):
--   (s, zero, plus) is a commutative monoid
--   (s, one, mult) is a monoid
--   mult x zero = zero = mult zero x (annihilation)
--   mult distributes over plus
form UsageSemiring := \(s: Type). {
  zero: s;
  one: s;
  plus: s -> s -> s;
  mult: s -> s -> s
}

impl UsageSemiring Trivial := {
  zero := Triv;
  one := Triv;
  plus := \_ _. Triv;
  mult := \_ _. Triv
}

-- GIMonad: the canonical indexed monad class, parameterized by grade algebra.
form GIMonad := \(g: Kind) (m: g -> Row -> Row -> Type -> Type). GradeAlgebra g => {
  gipure: \a (r: Row). a -> m GradeDrop r r a;
  gibind: \a b (e1: g) (e2: g) (r1: Row) (r2: Row) (r3: Row).
              m e1 r1 r2 a -> (a -> m e2 r2 r3 b) -> m (GradeCompose e1 e2) r1 r3 b
}

-- Lift an ordinary monad into the indexed monad world.
type Lift := \(m: Type -> Type) (g: Kind) (r1: Row) (r2: Row) a. m a

-- Effectful computation that preserves the capability row.
type Effect := \r a. Computation Zero r r a

-- Suspended (thunked) effectful computation.
type Suspended := \r a. Thunk Zero r r a

-- Computation is a canonical GIMonad instance: grade-parametric over any
-- grade algebra g. The single instance covers all grade kinds (Mult, Level, etc.)
-- because g is universally quantified.
impl GradeAlgebra g => GIMonad g Computation := {
  gipure := pure;
  gibind := bind
}

-- SMC Phase 2: Parallel Composition
-- merge splits capability environments and runs both computations independently.
-- pre/post rows must be disjoint (enforced by Merge type family).
merge :: \a b (pre1: Row) (post1: Row) (pre2: Row) (post2: Row).
         Computation pre1 post1 a -> Computation pre2 post2 b
         -> Computation (Merge pre1 pre2) (Merge post1 post2) (a, b)
merge := assumption

-- Infix alias for merge.
infixr 3 ***
(***) :: \a b (pre1: Row) (post1: Row) (pre2: Row) (post2: Row).
         Computation pre1 post1 a -> Computation pre2 post2 b
         -> Computation (Merge pre1 pre2) (Merge post1 post2) (a, b)
(***) := merge

-- SMC Phase 3: Dagger
-- dag swaps pre and post capability rows. dag (dag f) = f by construction.
type Gate := \(pre: Row) (post: Row). Computation pre post ()

dag :: \(pre: Row) (post: Row). Gate pre post -> Gate post pre
dag := assumption

