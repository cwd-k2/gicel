import Prelude

get :: forall s r. Computation { state : s | r } { state : s | r } s
get := assumption

put :: forall s r. s -> Computation { state : s | r } { state : s | r } ()
put := assumption

modify :: forall s r. (s -> s) -> Computation { state : s | r } { state : s | r } ()
modify := \f -> do { s <- get; put (f s) }
