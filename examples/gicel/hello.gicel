-- GICEL Example: Hello World
--
-- The simplest GICEL program. Imports Std.Num for integers and Std.Str
-- for strings, defines a greeting and computes 6 * 7, then returns both
-- as a tuple.
-- Level: basics

import Prelude

-- A simple string binding
greeting := "Hello, GICEL!"

-- Arithmetic expression
answer := 6 * 7

-- The entry point: a tuple of (String, Int)
-- Output: ("Hello, GICEL!", 42)
main := (greeting, answer)
