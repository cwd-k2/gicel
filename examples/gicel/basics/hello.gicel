-- GICEL Example: Hello World
--
-- The classic first program. Uses the Console pack for real stdout output.
-- Run with: gicel run examples/gicel/basics/hello.gicel
--
-- Output:
--   Hello, GICEL!
--   6 * 7 = 42

import Prelude
import Console

main := do {
  putLine "Hello, GICEL!";
  putLine ("6 * 7 = " <> show (6 * 7))
}
