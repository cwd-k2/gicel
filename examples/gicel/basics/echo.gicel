-- GICEL Example: Echo
--
-- Reads a line from stdin, echoes it back with a greeting.
-- Demonstrates Console getLine + putLine for interactive programs.
--
-- Run: bin/gicel run examples/gicel/basics/echo.gicel
-- Then type a line and press Enter.
--
-- Input:  Alice
-- Output:
--   What is your name?
--   Hello, Alice!

-- gicel: --packs prelude,console
import Prelude
import Console

main := do {
  putLine "What is your name?";
  name <- getLine;
  putLine $ "Hello, " <> name <> "!"
}
