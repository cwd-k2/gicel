-- GICEL Example: IO Effect
--
-- The IO pack provides print and debug capabilities
-- that write to the CapEnv io buffer.
-- Run: bin/gicel run examples/gicel/effects/io.gicel

import Prelude
import Effect.IO

-- Side effects: prints "hello, world!" and debug "done" to the io buffer.
-- Return value: ()
main := do {
  print "hello, ";
  print $ "world" <> "!";
  debug "done"
}
