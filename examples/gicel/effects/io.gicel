-- GICEL Example: IO Effect
--
-- The IO pack provides log and dbg capabilities
-- that write to the CapEnv io buffer.
-- Run: bin/gicel run examples/gicel/effects/io.gicel

import Prelude
import Effect.IO
import Console

-- Effect.IO writes to the capEnv io buffer (for Go embedding).
-- Console.putLine writes to stdout (for CLI output).
main := do {
  log "hello, ";
  log $ "world" <> "!";
  dbg "done";
  putLine "IO effect: wrote to capEnv.io buffer";
  putLine "(visible via --json)"
}
