-- GICEL Example: Multi-Module Imports
--
-- Demonstrates selective and qualified import forms.
-- This example uses inline modules registered by the Go host;
-- for CLI multi-file usage, see the Go example at examples/go/multi-module.
-- Level: types

import Prelude

-- Open import: all names unqualified (standard form, used for Prelude above)

-- Result: a tuple of (String, Int)
-- Output: ("Hello, GICEL!", 42)
main := ("Hello, GICEL!", 42)
